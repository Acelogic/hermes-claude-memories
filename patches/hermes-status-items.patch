+        """Plugins can register status bar items for the CLI footer."""
+        mgr = PluginManager()
+        ctx = PluginContext(PluginManifest(name="status-plugin", source="user"), mgr)
+
+        ctx.register_status_item("later", lambda **kw: [("class:status-bar", " later")], priority=50)
+        ctx.register_status_item("earlier", lambda **kw: [("class:status-bar", " earlier")], priority=10)
+
+        items = mgr.get_status_items()
+
+        assert [item["name"] for item in items] == ["earlier", "later"]
