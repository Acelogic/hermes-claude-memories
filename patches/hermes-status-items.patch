         self._manager._hooks.setdefault(hook_name, []).append(callback)
         logger.debug("Plugin %s registered hook: %s", self.manifest.name, hook_name)
 
+    # -- status bar registration -------------------------------------------
+
+    def register_status_item(
+        self,
+        name: str,
+        callback: Callable,
+        priority: int = 100,
+    ) -> None:
+        """Register a CLI status-bar item.
+
+        The callback is called by the interactive CLI footer renderer with
+        keyword context such as ``cli``, ``snapshot`` and ``width``. It may
+        return either a prompt_toolkit fragment list ``[(style, text), ...]``
+        or a plain string. Lower priority values render earlier.
+        """
+        clean = name.lower().strip().replace(" ", "-")
+        if not clean:
+            logger.warning(
+                "Plugin '%s' tried to register a status item with an empty name.",
+                self.manifest.name,
+            )
+            return
+        self._manager._status_items[clean] = {
+            "name": clean,
+            "callback": callback,
+            "priority": int(priority),
+            "plugin": self.manifest.name,
+        }
+        logger.debug("Plugin %s registered status item: %s", self.manifest.name, clean)
+
